{
  "manifest_version": 3,
  "name": "CAPTCHA Vision Assistant",
  "version": "1.0.0",
  "description": "AI-powered CAPTCHA detection and prediction.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>", "http://localhost:8000/"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "index.html",
    "default_title": "Open Assistant"
  }
}
